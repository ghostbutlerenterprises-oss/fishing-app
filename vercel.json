{
        "version": 2,
          "buildCommand": "cd frontend && npm run build",
            "builds": [
                {
                      "src": "api/index.js",
                            "use": "@vercel/node"
                                }
                                  ],
                                    "routes": [
                                        {
                                              "src": "/api/(.*)",
                                                    "dest": "api/index.js"
                                                        },
                                                            {
                                                                  "src": "/",
                                                                        "dest": "/frontend/dist/index.html"
                                                                            },
                                                            {
                                                                  "src": "/(.*)",
                                                                        "dest": "/frontend/dist/index.html"
                                                                            }
                                                                              ]
                                                                              }