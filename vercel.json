{
        "version": 2,
          "buildCommand": "cd frontend && npm run build",
            "builds": [
                {
                      "src": "frontend/dist/**",
                            "use": "@vercel/static"
                                },
                                    {
                                          "src": "api/index.js",
                                                "use": "@vercel/node"
                                                    }
                                                      ],
                                                        "routes": [
                                                            {
                                                                  "src": "/api/(.*)",
                                                                        "dest": "api/index.js"
                                                                            },
                                                                                {
                                                                                      "src": "/(.*)",
                                                                                            "dest": "frontend/dist/$1"
                                                                                                }
                                                                                                  ]
                                                                                                  }
}