# Server Configuration
PORT=5000
HOST=localhost
NODE_ENV=development

# Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=anglers_log
DB_PASSWORD=your_password_here
DB_PORT=5432

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# External APIs (Phase 2)
OPENWEATHER_API_KEY=your_openweather_key_here
TIDES_API_KEY=your_tides_key_here
TIDES_API_URL=https://api.tides.net/v1

# AWS S3 (Phase 2)
AWS_ACCESS_KEY_ID=optional_for_phase2
AWS_SECRET_ACCESS_KEY=optional_for_phase2
AWS_S3_BUCKET=optional_for_phase2
AWS_REGION=us-east-1
